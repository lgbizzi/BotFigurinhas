# Telegram
TELEGRAM_BOT_TOKEN=<CHANGE_ME>

# =============================================================================
# PostgreSQL — HomeLab
# =============================================================================

# --- Credenciais da aplicação (usadas pelo bot) ---
# POSTGRES_HOST deve ser "db" (nome do serviço Docker) em produção
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=homelab
POSTGRES_USER=lg.admin
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_SCHEMA=AlbumCopa2026

# --- Credenciais de administração do container ---
# Usadas apenas na inicialização do container PostgreSQL
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=<CHANGE_ME>

# --- Pool de conexões ---
DB_POOL_MIN=1
DB_POOL_MAX=10

# =============================================================================
# Opcional — banco de origem para migração de dados
# Preencha apenas ao executar database/migrate_from_informapromo.sh
# =============================================================================
SRC_POSTGRES_HOST=localhost
SRC_POSTGRES_PORT=5432
SRC_POSTGRES_DB=<CHANGE_ME>
SRC_POSTGRES_USER=<CHANGE_ME>
SRC_POSTGRES_PASSWORD=<CHANGE_ME>
