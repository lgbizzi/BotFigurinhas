# Telegram
TELEGRAM_BOT_TOKEN=<CHANGE_ME>

# PostgreSQL
# POSTGRES_HOST deve ser "db" (nome do serviço Docker) — não altere em produção Docker
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=<CHANGE_ME>
POSTGRES_USER=<CHANGE_ME>
POSTGRES_PASSWORD=<CHANGE_ME>

# Pool de conexões
DB_POOL_MIN=1
DB_POOL_MAX=10
