# =============================================================================
# Bot Figurinhas Copa 2026 — Template de variáveis de ambiente
#
# Copie este arquivo para .env e preencha os valores antes de subir os containers:
#   cp .env.example .env
#
# Campos marcados com <CHANGE_ME> são obrigatórios e não possuem valor padrão.
# Campos com valor pré-preenchido são sugestões — você pode alterá-los,
# mas mantenha consistência entre todas as ocorrências.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram
# Obtenha o token conversando com @BotFather em https://t.me/BotFather
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=<CHANGE_ME>

# -----------------------------------------------------------------------------
# PostgreSQL — Credenciais da aplicação
# Usadas pelo bot para se conectar ao banco em tempo de execução.
# POSTGRES_HOST deve ser "db" (nome do serviço Docker) quando rodando
# via docker compose. Use "localhost" apenas para execução local sem Docker.
# -----------------------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=homelab
POSTGRES_USER=lg.admin
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_SCHEMA=AlbumCopa2026

# -----------------------------------------------------------------------------
# PostgreSQL — Credenciais de administração do container
# Usadas APENAS durante a inicialização do container PostgreSQL para criar
# o role de aplicação e o schema. Não são usadas pelo bot em execução.
# Nunca altere POSTGRES_ADMIN_USER após o volume pgdata já existir.
# -----------------------------------------------------------------------------
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=<CHANGE_ME>

# -----------------------------------------------------------------------------
# Pool de conexões
# -----------------------------------------------------------------------------
DB_POOL_MIN=1
DB_POOL_MAX=10

# -----------------------------------------------------------------------------
# Migração de dados (opcional)
# Preencha apenas ao executar database/migrate_from_informapromo.sh para
# copiar dados de um banco PostgreSQL anterior para o homelab.
# -----------------------------------------------------------------------------
SRC_POSTGRES_HOST=<CHANGE_ME>
SRC_POSTGRES_PORT=5432
SRC_POSTGRES_DB=<CHANGE_ME>
SRC_POSTGRES_USER=<CHANGE_ME>
SRC_POSTGRES_PASSWORD=<CHANGE_ME>
